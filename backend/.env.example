CHATKU_API_KEY=your_chatku_api_key
CHATKU_BASE_URL=https://factchat-cloud.mindlogic.ai/v1/gateway
CHATKU_MODEL=gpt-5.4
CHATKU_MODEL_PLANNER=gpt-5.4
CHATKU_MODEL_EXTRACTOR=gpt-5.4-mini
CHATKU_MODEL_FOLLOWUP=gpt-5.4-mini
CHATKU_MODEL_SUMMARY=gpt-5.4-nano
CHATKU_TIMEOUT_SECONDS=12
CHATKU_MAX_RETRIES=1

NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_TIMEOUT_SECONDS=12
NAVER_MAX_RETRIES=2

DATABASE_URL=sqlite:///./shopping_agent.db
# DATABASE_URL=postgresql+psycopg://shopping_user:shopping_password@localhost:5432/shopping_agent
FRONTEND_ORIGIN=http://localhost:3000
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800
PLANNER_CACHE_TTL_SECONDS=1800
NAVER_CACHE_TTL_SECONDS=600
LLM_CACHE_TTL_SECONDS=900
PLANNER_LLM_THRESHOLD=3
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
HOME_CACHE_TTL_SECONDS=300
