[Unit]
Description=Shopping AI Agent Backend
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/shopping-agent-mvp/backend
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/ubuntu/shopping-agent-mvp/backend/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
